[Unit]
Description=Fix screen rotation after resume for dmytro
After=suspend.target

[Service]
Type=oneshot
User=dmytro
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
Environment=XDG_RUNTIME_DIR=/run/user/1000
ExecStart=/usr/bin/python3 /usr/local/bin/fix-rotation.py

[Install]
WantedBy=suspend.target