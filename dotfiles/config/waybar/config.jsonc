{
    "layer": "top",
    "modules-left": ["pulseaudio"],
    "modules-center": ["clock", "hyprland/workspaces"],
    "modules-right": ["battery"],
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "clock": {
        "format-alt": "{:%a, %d. %b  %H:%M}"
    }
}